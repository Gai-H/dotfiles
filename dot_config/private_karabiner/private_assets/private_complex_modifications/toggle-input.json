{
  "title": "Toggle Input",
  "rules": [
    {
      "description": "Toggle Input",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "japanese_pc_xfer",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "japanese_pc_xfer",
              "lazy": true
            }
          ],
          "to_if_alone": [
            { "key_code": "japanese_kana" }
          ],
          "to_if_held_down": [
            { "key_code": "japanese_pc_xfer" }
          ],
          "conditions": [
            {
              "type": "input_source_if",
              "input_sources": [
                { "language": "^en$" }
              ]
            }
          ],
          "parameters": {
            "basic.to_if_held_down_threshold_milliseconds": 100
          }
        },
        {
          "type": "basic",
          "from": {
            "key_code": "japanese_pc_nfer",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "japanese_pc_nfer",
              "lazy": true
            }
          ],
          "to_if_alone": [
            { "key_code": "japanese_eisuu" }
          ],
          "to_if_held_down": [
            { "key_code": "japanese_pc_nfer" }
          ],
          "conditions": [
            {
              "type": "input_source_if",
              "input_sources": [
                { "language": "^ja$" }
              ]
            }
          ],
          "parameters": {
            "basic.to_if_held_down_threshold_milliseconds": 100
          }
        }
      ]
    }
  ]
}
