            { "type": "variable_if", "name": "f24_virtual", "value": 1 },
            { "type": "variable_if", "name": "f21_virtual", "value": 0 },
            { "type": "variable_if", "name": "f22_virtual", "value": 0 },
            { "type": "variable_if", "name": "f23_virtual", "value": 0 }
          ],
          "to": [ { "key_code": "c", "modifiers": ["command"] } ]
