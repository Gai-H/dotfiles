{
  "title": "F22_Kitty_Neovim",
  "rules": [
    {
      "description": "F22_Kitty_Neovim",
      "manipulators": [
        {
          "type": "basic",
          "from": { "any": "key_code", "modifiers": { "optional": ["any"] } },
          "to": [{ "from_event": true, "modifiers": ["control"] }],
          "conditions": [
            { "type": "frontmost_application_if", "bundle_identifiers": ["^net\\.kovidgoyal\\.kitty$"] },
            { "type": "variable_if", "name": "f22_virtual", "value": 1 },
            { "type": "variable_if", "name": "f21_virtual", "value": 0 },
            { "type": "variable_if", "name": "f23_virtual", "value": 0 },
            { "type": "variable_if", "name": "f24_virtual", "value": 0 },
            { "type": "variable_if", "name": "kitty_user-variables", "value": "{\"mode\":\"neovim\"}" }
          ]
        }
      ]
    }
  ]
}
