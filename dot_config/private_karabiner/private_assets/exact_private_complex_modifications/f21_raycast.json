{
  "title": "F21_Raycast",
  "rules": [
    {
      "description": "F21_Raycast",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "spacebar",
            "modifiers": { "optional": [] }
          },
          "to": [
            {
              "key_code": "spacebar",
              "modifiers": ["left_option"]
            }
          ],
          "conditions": [
            { "type": "variable_if", "name": "f21_virtual", "value": 1 },
            { "type": "variable_if", "name": "f22_virtual", "value": 0 },
            { "type": "variable_if", "name": "f23_virtual", "value": 0 },
            { "type": "variable_if", "name": "f24_virtual", "value": 0 }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "tab",
            "modifiers": { "optional": [] }
          },
          "to": [
            {
              "shell_command": "~/.config/karabiner/assets/complex_modification_tweaks/f21_raycast/launch-aerospace-workspace-switcher-extension.sh 1"
            }
          ],
          "conditions": [
            { "type": "variable_if", "name": "f21_virtual", "value": 1 },
            { "type": "variable_if", "name": "f22_virtual", "value": 0 },
            { "type": "variable_if", "name": "f23_virtual", "value": 0 },
            { "type": "variable_if", "name": "f24_virtual", "value": 0 }
          ]
        }
      ]
    }
  ]
}
